# .env.example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# =====================================================================
# DJANGO SETTINGS
# =====================================================================
DJANGO_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# =====================================================================
# DATABASE (Railway PostgreSQL)
# =====================================================================
# Railway will set this automatically - copy from Railway dashboard
DATABASE_URL=postgresql://user:password@host:port/dbname

# =====================================================================
# EMAIL CONFIGURATION
# =====================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@helios.example
ADMIN_EMAIL=admin@helios.example
BUSINESS_CONTACT_EMAIL=solchartzm@gmail.com

# =====================================================================
# MVP PAYMENT SYSTEM (TEMPORARY MANUAL PAYMENT)
# =====================================================================
# NOTE: This is a temporary solution for MVP phase.
# Replace with proper payment gateway (Stripe, Flutterwave, etc.) later.
# See settings.py for upgrade notes.
BUSINESS_ACCOUNT_NAME=Solchart (Zambia) Ltd
BUSINESS_BANK_ACCOUNT=XXXXX-XXXXX-XXXXX  # Replace with actual bank account

# =====================================================================
# FUTURE PAYMENT GATEWAY INTEGRATION
# =====================================================================
# Uncomment and fill in when you're ready to integrate a payment provider

# Payment Provider Choice (manual, payfast, zamtel, airtel)
# PAYMENT_PROVIDER=manual

# --- Payfast Configuration (if using) ---
# PAYFAST_MERCHANT_ID=10000001
# PAYFAST_MERCHANT_KEY=abcd1234
# PAYFAST_API_KEY=pk_test_abcd1234
# PAYFAST_SANDBOX=true

# --- Zamtel API Configuration (if using) ---
# ZAMTEL_API_KEY=your-api-key
# ZAMTEL_API_SECRET=your-api-secret

# --- Airtel Money Configuration (if using) ---
# AIRTEL_CLIENT_ID=your-client-id
# AIRTEL_CLIENT_SECRET=your-client-secret

# --- Webhook Security (for all API providers) ---
# WEBHOOK_SECRET=your-webhook-secret-key

# =====================================================================
# MEDIA & STATIC FILES
# =====================================================================
# For local development - AWS S3 for production
MEDIA_URL=/media/
MEDIA_ROOT=media/
STATIC_URL=/static/

# If using AWS S3 (production)
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name

# =====================================================================
# LOGGING
# =====================================================================
LOG_LEVEL=INFO

# =====================================================================
# SECURITY (Production)
# =====================================================================
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# =====================================================================
# SELLER SETTINGS
# =====================================================================
TEST_SELLER_EMAIL=test.seller@example.com
